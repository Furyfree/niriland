// Zed keymap
//
// Keep this file small and focused on shortcuts that differ from Zed's
// VS Code-style defaults. Default keymap reference:
// zed: open default keymap
[
  // --- Agent ---
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-shift-a": "agent::ToggleFocus"
    }
  },
  {
    "context": "Editor && mode == full",
    "bindings": {
      "ctrl-shift-a": "agent::ToggleFocus"
    }
  },

  // --- Projects ---
  {
    "bindings": {
      "ctrl-shift-o": [
        "projects::OpenRecent",
        {
          "create_new_window": true
        }
      ]
    }
  },

  // --- Docks & Panels ---
  {
    "context": "Workspace",
    "bindings": {
      // Danish keyboard friendly bottom dock shortcut.
      "ctrl-j": "workspace::ToggleBottomDock",

      // Swap the default outline/right-dock shortcuts.
      "ctrl-shift-b": "workspace::ToggleRightDock",
      "ctrl-alt-b": "outline_panel::ToggleFocus"
    }
  },

  // --- Optional Experiments ---
  {
    "context": "Workspace",
    "bindings": {
      // "shift shift": "file_finder::Toggle"
    }
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      // "j k": "vim::NormalBefore"
    }
  }
]
