#!/usr/bin/env bash

set -euo pipefail

command -v pacman >/dev/null 2>&1 || { echo "Missing required command: pacman" >&2; exit 1; }
command -v sudo >/dev/null 2>&1 || { echo "Missing required command: sudo" >&2; exit 1; }

user="${SUDO_USER:-${USER:-}}"
[[ -n "$user" ]] || { echo "Could not determine target user." >&2; exit 1; }

if [[ "${1:-}" == "help" || "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  echo "Usage: niriland-setup-vm"
  exit 0
fi

if [[ $# -gt 0 ]]; then
  echo "Usage: niriland-setup-vm" >&2
  exit 1
fi

sudo -v || { echo "sudo authentication failed" >&2; exit 1; }
command -v paru >/dev/null 2>&1 || { echo "Missing required command: paru" >&2; exit 1; }

echo "Installing libvirt packages..."
sudo pacman -S --needed --noconfirm qemu-full virt-manager swtpm

echo "Configuring libvirt firewall backend..."
sudo install -d /etc/libvirt
if [[ "$(sudo cat /etc/libvirt/network.conf 2>/dev/null || true)" != *'firewall_backend = "iptables"'* ]]; then
  printf '%s\n' 'firewall_backend = "iptables"' | sudo tee -a /etc/libvirt/network.conf >/dev/null
fi

if id -nG "$user" | grep -qw libvirt; then
  echo "User $user is already in the libvirt group."
else
  echo "Adding $user to the libvirt group..."
  sudo usermod -aG libvirt "$user"
  echo "Log out and back in (or reboot) for the libvirt group change to take effect."
fi

echo "Enabling libvirtd.service..."
sudo systemctl enable --now libvirtd.service
echo "Enabling libvirtd.socket..."
sudo systemctl enable --now libvirtd.socket

if command -v virsh >/dev/null 2>&1 && sudo virsh net-info default >/dev/null 2>&1; then
  if ! sudo virsh net-list --name | grep -Fxq default; then
    echo "Starting libvirt default network..."
    sudo virsh net-start default
  fi
  echo "Enabling libvirt default network autostart..."
  sudo virsh net-autostart default
else
  echo "Skipping libvirt default network setup because virsh/default network is unavailable."
fi

if command -v ufw >/dev/null 2>&1; then
  if sudo ufw status 2>/dev/null | grep -Fq '192.168.122.0/24'; then
    echo "ufw already has a rule for 192.168.122.0/24."
  else
    echo "Adding ufw route allowance for 192.168.122.0/24..."
    sudo ufw route allow from 192.168.122.0/24
  fi
else
  echo "Skipping ufw rule because ufw is not installed."
fi

echo "Installing quickemu packages..."
paru -S --needed --noconfirm quickemu-git quickgui
