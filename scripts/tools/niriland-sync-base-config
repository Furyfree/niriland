validate_preset_coverage() {
  local preset
  local rel_path
  declare -A covered_paths=()

  for preset in "${!PRESET_TO_PATH[@]}"; do
    rel_path="${PRESET_TO_PATH[$preset]}"
    [[ -n "${TRACKED_PATH_SET[$rel_path]:-}" ]] || die "Preset points to untracked base config: $preset -> $rel_path"
    covered_paths["$rel_path"]=1
  done

  for rel_path in "${ALL_TRACKED_PATHS[@]}"; do
    [[ -n "${covered_paths[$rel_path]:-}" ]] || die "Missing preset for tracked base config: $rel_path"
  done
}

emit_presets() {
  local preset

  for preset in "${!PRESET_TO_PATH[@]}"; do
    printf '%s\t%s\n' "$preset" "${PRESET_TO_PATH[$preset]}"
  done | sort
}

list_presets() {
  emit_presets | awk -F '\t' '
    {
      rows[NR] = $0
      if (length($1) > max) {
        max = length($1)
      }
    }
    END {
      for (i = 1; i <= NR; i++) {
        split(rows[i], parts, "\t")
        printf "%-*s  %s\n", max, parts[1], parts[2]
      }
    }
  '
}

_niriland_preview_base_config() {
  local rel_path="${1:-}"
  local src="$BASE_CONFIG_DIR/$rel_path"
  local dest="$HOME/$rel_path"
  local mime_type

  [[ -n "$rel_path" ]] || return 0

  printf 'Repo: %s\n' "$src"
  printf 'Home: %s\n' "$dest"

  if [[ -e "$dest" || -L "$dest" ]]; then
    printf 'Status: existing target\n'
  else
    printf 'Status: target missing\n'
  fi

  printf '\n'

  if [[ -L "$src" ]]; then
    printf 'Symlink -> %s\n' "$(readlink "$src")"
    return 0
  fi

  mime_type="$(file --brief --mime-type "$src" 2>/dev/null || true)"

  if [[ "$mime_type" == text/* || "$mime_type" == application/json || "$mime_type" == application/xml || "$mime_type" == application/x-shellscript || "$mime_type" == inode/x-empty ]]; then
    if command -v bat >/dev/null 2>&1; then
      bat --style=plain --color=always --line-range=:200 -- "$src" 2>/dev/null || sed -n '1,200p' "$src"
    else
      sed -n '1,200p' "$src"
    fi
    return 0
  fi

  file --brief "$src" 2>/dev/null || true
}

export -f _niriland_preview_base_config

pick_presets() {
  local query="${1:-}"
  local preview_cmd='_niriland_preview_base_config {2}'
  local -a fzf_args=()
  local -a selected=()
  local entry
  local preset
  local rel_path

  require_cmd fzf
  require_cmd file

  fzf_args=(
    --multi
    --exact
    --delimiter $'\t'
    --with-nth '1,2'
    --nth '1,2'
    --prompt 'sync-config> '
    --header 'tab: select, enter: apply, alt-p: toggle preview'
    --preview "$preview_cmd"
    --preview-label 'tracked config preview'
    --preview-label-pos bottom
    --preview-window 'right:60%:wrap'
    --bind 'alt-p:toggle-preview'
    --bind 'alt-d:preview-half-page-down,alt-u:preview-half-page-up'
    --bind 'alt-k:preview-up,alt-j:preview-down'
  )

  if [[ -n "$query" ]]; then
    fzf_args+=(--query "$query")
  fi

  mapfile -t selected < <(
    emit_presets | SHELL="$(command -v bash)" fzf "${fzf_args[@]}" || true
  )

  if [[ ${#selected[@]} -eq 0 ]]; then
    log "No config presets selected."
    return 0
  fi

  for entry in "${selected[@]}"; do
    preset="${entry%%$'\t'*}"
    rel_path="${entry#*$'\t'}"
    [[ -n "$preset" && -n "$rel_path" ]] || continue
    append_unique "$rel_path"
  done
}

resolve_preset() {
  local preset="$1"

  if [[ -n "${PRESET_TO_PATH[$preset]:-}" ]]; then
    printf '%s\n' "${PRESET_TO_PATH[$preset]}"
    return 0
  fi

  if [[ -n "${TRACKED_PATH_SET[$preset]:-}" ]]; then
    printf '%s\n' "$preset"
    return 0
  fi

  return 1
}

append_unique() {
  local candidate="$1"
  local existing

  for existing in "${TARGETS[@]:-}"; do
    [[ "$existing" == "$candidate" ]] && return 0
  done

  TARGETS+=("$candidate")
}

append_all_presets() {
  local rel_path

  for rel_path in "${ALL_TRACKED_PATHS[@]}"; do
    append_unique "$rel_path"
  done
}

validate_rel_path() {
  local rel_path="$1"

  case "$rel_path" in
    ""|/*|../*|*/../*|..)
      die "Invalid relative path: $rel_path"
      ;;
    PLACEHOLDER|*/PLACEHOLDER)
      die "Refusing to sync placeholder path: $rel_path"
      ;;
  esac
}

sync_target() {
  local rel_path="$1"
  local src="$BASE_CONFIG_DIR/$rel_path"
  local dest="$HOME/$rel_path"
  local backup_path

  [[ -e "$src" || -L "$src" ]] || die "Tracked config not found: $src"

  mkdir -p "$(dirname "$dest")"

  if [[ -f "$src" && -f "$dest" ]] && cmp -s "$src" "$dest"; then
    log "$rel_path unchanged, skipping."
    return 0
  fi

  if [[ -L "$src" && -L "$dest" ]] && [[ "$(readlink "$src")" == "$(readlink "$dest")" ]]; then
    log "$rel_path unchanged, skipping."
    return 0
  fi

  if [[ -e "$dest" || -L "$dest" ]]; then
    backup_path="$BACKUP_ROOT/$rel_path"
    mkdir -p "$(dirname "$backup_path")"
    log "Backing up $dest -> $backup_path"
    cp -a "$dest" "$backup_path"
    rm -rf -- "$dest"
  fi

  log "Syncing $rel_path"
  cp -a "$src" "$dest"
}

[[ -d "$BASE_CONFIG_DIR" ]] || die "Missing base config directory: $BASE_CONFIG_DIR"

load_tracked_paths
register_known_presets
validate_preset_coverage

declare -a TARGETS=()
pick_mode=false
pick_query=""
initial_argc=$#

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help|-h)
      usage
      exit 0
      ;;
    --pick)
      pick_mode=true
      if [[ $# -ge 2 ]] && [[ "$2" != -* ]]; then
        pick_query="$2"
        shift 2
      else
        shift
      fi
      ;;
    --pick=*)
      pick_mode=true
      pick_query="${1#--pick=}"
      shift
      ;;
    --list)
      list_presets
      exit 0
      ;;
    --all)
      append_all_presets
      shift
      ;;
    --path)
      [[ $# -ge 2 ]] || die "--path requires a relative path argument"
      validate_rel_path "$2"
      append_unique "$2"
      shift 2
      ;;
    -*)
      die "Unknown option: $1"
      ;;
    *)
      if ! rel_path="$(resolve_preset "$1")"; then
        die "Unknown preset: $1 (use --list to inspect available presets)"
      fi

      append_unique "$rel_path"
      shift
      ;;
  esac
done

if [[ "$pick_mode" == "true" || "$initial_argc" -eq 0 ]]; then
  pick_presets "$pick_query"
fi

[[ ${#TARGETS[@]} -gt 0 ]] || die "No config targets selected."

BACKUP_TS="$(date +%Y%m%d%H%M%S)"
BACKUP_ROOT="$HOME/.config/backups/niriland/base-config-sync/$BACKUP_TS"

for rel_path in "${TARGETS[@]}"; do
  validate_rel_path "$rel_path"
  sync_target "$rel_path"
done

log "Backup root: $BACKUP_ROOT"
log_success "Synced ${#TARGETS[@]} tracked config path(s)."
